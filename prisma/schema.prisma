generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model Student {
  id        String         @id @default(cuid())
  name      String
  email     String?        @unique
  track     Track
  createdAt DateTime       @default(now())
  sessions  Session[]
  quizzes   QuizResult[]
  progress  WeekProgress[]
}

model Session {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  track     Track
  week      Int
  messages  Json
  createdAt DateTime @default(now())
}

model QuizResult {
  id        String   @id @default(cuid())
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])
  track     Track
  week      Int
  score     Int
  questions Json
  createdAt DateTime @default(now())
}

model WeekProgress {
  id        String     @id @default(cuid())
  studentId String
  student   Student    @relation(fields: [studentId], references: [id])
  week      Int
  status    WeekStatus
  updatedAt DateTime   @updatedAt

  @@unique([studentId, week])
}

model KnowledgeChunk {
  id        String                      @id @default(cuid())
  source    String
  content   String
  embedding Unsupported("vector(768)")?
  createdAt DateTime                    @default(now())
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      AuthSession[]
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
}

enum Track {
  DEVELOPER
  PROFESSIONAL
}

enum WeekStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

model Applicant {
  id                String               @id @default(cuid())
  name              String
  email             String?
  phone             String?
  messages          Json
  scores            Json?
  developerScore    Int?
  professionalScore Int?
  prepScore         Int?
  recommendation    TrackRecommendation?
  reasoning         String?
  status            ApplicantStatus      @default(PENDING)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  prepEnrollment    PrepEnrollment?
}

model PrepEnrollment {
  id                  String      @id @default(cuid())
  applicantId         String      @unique
  applicant           Applicant   @relation(fields: [applicantId], references: [id])
  currentModule       Int         @default(1)
  moduleProgress      Json        @default("{}")
  miniProjectUrl      String?
  miniProjectScore    Int?
  miniProjectFeedback String?
  exitAssessmentId    String?
  status              PrepStatus  @default(ACTIVE)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

enum TrackRecommendation {
  DEVELOPER
  PROFESSIONAL
  PREP
  NOT_READY
}

enum ApplicantStatus {
  PENDING
  ASSESSED
  ACCEPTED
  REJECTED
}

enum PrepStatus {
  ACTIVE
  READY_FOR_EXIT
  GRADUATED
  DEFERRED
}
